---
import MainLayout from "../../layouts/MainLayout.astro";
import AuthInit from "../../islands/AuthInit.tsx";
import LoginForm from "../../islands/LoginForm.tsx";
---

<MainLayout title="Iniciar sesión — TechStore">
  <AuthInit client:only="react" />
  <div class="mx-auto flex min-h-[70vh] max-w-md items-center justify-center px-4 py-16">
    <div class="w-full">
      <h1 class="mb-2 text-center text-2xl font-bold text-text-primary">Iniciar sesión</h1>
      <p class="mb-8 text-center text-sm text-text-muted">
        ¿No tenés cuenta?{" "}
        <a href="/auth/register" class="text-violet-400 hover:text-violet-300">Registrate</a>
      </p>
      <LoginForm client:only="react" />
    </div>
  </div>
</MainLayout>
