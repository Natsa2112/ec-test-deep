---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Página no encontrada — TechStore">
  <div class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <h1 class="mb-4 text-8xl font-bold text-violet-500/30">404</h1>
    <h2 class="mb-2 text-2xl font-bold text-text-primary">Página no encontrada</h2>
    <p class="mb-8 text-text-secondary">La página que buscás no existe o fue movida.</p>
    <a href="/" class="rounded-lg bg-violet-600 px-6 py-2.5 text-sm font-medium text-white hover:bg-violet-500 transition-colors">
      Volver al inicio
    </a>
  </div>
</MainLayout>
