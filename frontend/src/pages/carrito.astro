---
import MainLayout from "../layouts/MainLayout.astro";
import Breadcrumb from "../components/molecules/Breadcrumb.astro";
import AuthInit from "../islands/AuthInit.tsx";
import CartContent from "../islands/CartContent.tsx";
---

<MainLayout title="Carrito de compras — TechStore">
  <AuthInit client:only="react" />
  <div class="mx-auto max-w-4xl px-4 py-8">
    <Breadcrumb items={[{ label: "Inicio", href: "/" }, { label: "Carrito" }]} class="mb-6" />
    <h1 class="mb-8 text-3xl font-bold text-text-primary">Carrito de compras</h1>
    <CartContent client:only="react" />
  </div>
</MainLayout>
