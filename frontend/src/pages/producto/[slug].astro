---
import MainLayout from "../../layouts/MainLayout.astro";
import Breadcrumb from "../../components/molecules/Breadcrumb.astro";
import ProductCard from "../../components/atoms/ProductCard.astro";
import ImageGallery from "../../islands/ImageGallery.tsx";
import AddToCartButton from "../../islands/AddToCartButton.tsx";

const API = import.meta.env.PUBLIC_API_URL;
const { slug } = Astro.params;

let producto: any = null;
let related: any[] = [];

try {
  const res = await fetch(`${API}/productos/${slug}`);
  producto = await res.json();
  const relRes = await fetch(`${API}/productos?limit=4&categoria=${producto.categoria?.slug ?? ""}`);
  const relData = await relRes.json();
  related = relData.productos.filter((p: any) => p.slug !== slug).slice(0, 3);
} catch (e) {
  console.error("Error fetching product:", e);
}

if (!producto) {
  return Astro.redirect("/404");
}

function formatPrice(p: number) {
  return `$${p.toLocaleString("es-AR")}`;
}
---

<MainLayout title={`${producto.nombre} — TechStore`}>
  <div class="mx-auto max-w-6xl px-4 py-8">
    <Breadcrumb items={[
      { label: "Inicio", href: "/" },
      { label: "Productos", href: "/productos" },
      { label: producto.categoria?.nombre ?? "" },
      { label: producto.nombre },
    ]} class="mb-6" />

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
      <ImageGallery client:visible />

      <div>
        <div class="mb-2 flex items-center gap-2 text-sm text-text-muted">
          <span>{producto.marca}</span>
          {producto.sku && <><span>•</span><span>{producto.sku}</span></>}
        </div>
        <h1 class="mb-4 text-3xl font-bold text-text-primary">{producto.nombre}</h1>

        <div class="mb-4 flex items-center gap-3">
          <div class="flex items-center gap-1">
            {Array.from({ length: 5 }, (_, i) => (
              <svg key={i} class={`h-4 w-4 ${i < Math.round(Number(producto.rating)) ? "text-amber-400" : "text-bg-elevated"}`} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-sm text-text-secondary">({producto.resenas?.length ?? 0} reseñas)</span>
        </div>

        <p class="mb-6 text-text-secondary">{producto.descripcion}</p>

        <div class="mb-6 flex items-baseline gap-3">
          <span class="text-3xl font-bold text-text-primary">{formatPrice(Number(producto.precio))}</span>
          {producto.precioAnterior && (
            <span class="text-lg text-text-muted line-through">{formatPrice(Number(producto.precioAnterior))}</span>
          )}
          {producto.descuento > 0 && (
            <span class="rounded-full bg-amber-500 px-2.5 py-0.5 text-xs font-bold text-amber-950">
              -{producto.descuento}%
            </span>
          )}
        </div>

        <div class="mb-6 flex items-center gap-2 text-sm text-text-secondary">
          <span class={`h-2 w-2 rounded-full ${producto.stock > 0 ? "bg-emerald-400" : "bg-red-400"}`} />
          {producto.stock > 0 ? `${producto.stock} en stock` : "Sin stock"}
        </div>

        <div class="mb-8">
          <AddToCartButton client:load productoId={producto.id} stock={producto.stock} />
        </div>

        <div class="rounded-xl border border-border bg-bg-secondary p-4">
          <div class="flex items-center gap-4 text-sm">
            <div class="flex items-center gap-2 text-text-secondary">
              <svg class="h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Envío gratis
            </div>
            <div class="flex items-center gap-2 text-text-secondary">
              <svg class="h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              12 cuotas sin interés
            </div>
            <div class="flex items-center gap-2 text-text-secondary">
              <svg class="h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
              30 días de cambio
            </div>
          </div>
        </div>
      </div>
    </div>

    {producto.especificaciones?.length > 0 && (
      <section class="mt-16">
        <h2 class="mb-6 text-2xl font-bold text-text-primary">Especificaciones técnicas</h2>
        <div class="divide-y divide-border rounded-xl border border-border">
          {producto.especificaciones.map((spec: any) => (
            <div class="grid grid-cols-2 gap-4 px-6 py-3 text-sm even:bg-bg-secondary">
              <span class="text-text-muted">{spec.atributo}</span>
              <span class="text-text-primary">{spec.valor}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    {related.length > 0 && (
      <section class="mt-16">
        <h2 class="mb-6 text-2xl font-bold text-text-primary">Productos relacionados</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((p: any) => (
            <ProductCard
              key={p.slug}
              id={p.id}
              nombre={p.nombre}
              slug={p.slug}
              precio={Number(p.precio)}
              precioAnterior={p.precioAnterior ? Number(p.precioAnterior) : undefined}
              descuento={p.descuento}
              rating={Number(p.rating)}
              imagen={p.imagenes?.[0]}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</MainLayout>
