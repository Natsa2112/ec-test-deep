---
export interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
  class?: string;
}

const { currentPage, totalPages, baseUrl, class: className = "" } = Astro.props;

const pages = Array.from({ length: Math.min(totalPages, 7) }, (_, i) => {
  if (totalPages <= 7) return i + 1;
  if (currentPage <= 4) return i + 1;
  if (currentPage >= totalPages - 3) return totalPages - 6 + i;
  return currentPage - 3 + i;
});
---

<nav aria-label="Pagination" class={`flex items-center justify-center gap-1 ${className}`}>
  {currentPage > 1 && (
    <a href={`${baseUrl}?page=${currentPage - 1}`} class="rounded-lg border border-border px-3 py-2 text-sm text-text-secondary hover:bg-bg-elevated transition-colors">
      Anterior
    </a>
  )}
  {pages.map((page) => (
    <a
      href={`${baseUrl}?page=${page}`}
      class={`rounded-lg px-3 py-2 text-sm transition-colors ${
        page === currentPage
          ? "bg-violet-600 text-white"
          : "border border-border text-text-secondary hover:bg-bg-elevated"
      }`}
    >
      {page}
    </a>
  ))}
  {currentPage < totalPages && (
    <a href={`${baseUrl}?page=${currentPage + 1}`} class="rounded-lg border border-border px-3 py-2 text-sm text-text-secondary hover:bg-bg-elevated transition-colors">
      Siguiente
    </a>
  )}
</nav>
