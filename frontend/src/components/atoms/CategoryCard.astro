---
export interface Props {
  nombre: string;
  slug: string;
  imagenUrl?: string;
  class?: string;
}

const { nombre, slug, imagenUrl, class: className = "" } = Astro.props;
---

<a href={`/productos/${slug}`} class={`group block overflow-hidden rounded-xl border border-border bg-bg-tertiary shadow-sm transition-all hover:shadow-md hover:border-violet-800/50 ${className}`}>
  <div class="aspect-video bg-bg-secondary">
    {imagenUrl ? (
      <img src={imagenUrl} alt={nombre} loading="lazy" class="h-full w-full object-cover transition-transform group-hover:scale-105" />
    ) : (
      <div class="flex h-full items-center justify-center text-4xl text-text-muted">
        {nombre.charAt(0)}
      </div>
    )}
  </div>
  <div class="p-4">
    <h3 class="font-semibold text-text-primary group-hover:text-violet-400 transition-colors">{nombre}</h3>
  </div>
</a>
