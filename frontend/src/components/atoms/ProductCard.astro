---
export interface Props {
  id: string;
  nombre: string;
  slug: string;
  precio: number;
  precioAnterior?: number;
  descuento?: number;
  imagen?: string;
  rating?: number;
  class?: string;
}

const { nombre, slug, precio, precioAnterior, descuento, imagen, rating, class: className = "" } = Astro.props;

function formatPrice(price: number): string {
  return `$${price.toLocaleString("es-AR")}`;
}

const stars = rating ? Math.round(rating) : 0;
---

<a href={`/producto/${slug}`} class={`group flex flex-col overflow-hidden rounded-xl border border-border bg-bg-tertiary shadow-sm transition-all hover:shadow-md hover:border-violet-800/50 ${className}`}>
  <div class="relative aspect-square bg-bg-secondary">
    {imagen ? (
      <img src={imagen} alt={nombre} loading="lazy" class="h-full w-full object-cover transition-transform group-hover:scale-105" />
    ) : (
      <div class="flex h-full items-center justify-center text-text-muted">
        <svg class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
    {descuento && descuento > 0 && (
      <span class="absolute left-2 top-2 rounded-full bg-amber-500 px-2 py-0.5 text-xs font-bold text-amber-950">
        -{descuento}%
      </span>
    )}
  </div>
  <div class="flex flex-1 flex-col p-4">
    <h3 class="mb-1 text-sm font-medium text-text-primary line-clamp-2 group-hover:text-violet-400 transition-colors">{nombre}</h3>
    {rating && (
      <div class="mb-2 flex items-center gap-1">
        {Array.from({ length: 5 }, (_, i) => (
          <svg key={i} class={`h-3.5 w-3.5 ${i < stars ? "text-amber-400" : "text-bg-elevated"}`} fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
    )}
    <div class="mt-auto flex items-baseline gap-2">
      <span class="text-lg font-bold text-text-primary">{formatPrice(precio)}</span>
      {precioAnterior && (
        <span class="text-sm text-text-muted line-through">{formatPrice(precioAnterior)}</span>
      )}
    </div>
  </div>
</a>
