---
export interface Props {
  class?: string;
  variant?: "text" | "card" | "circle";
  width?: string;
  height?: string;
}

const { class: className = "", variant = "text", width, height } = Astro.props;
---

<div class={`animate-pulse rounded bg-bg-elevated ${className}`} style={{
  width: width ?? (variant === "circle" ? "3rem" : "100%"),
  height: height ?? (variant === "text" ? "1rem" : variant === "circle" ? "3rem" : "12rem"),
  borderRadius: variant === "circle" ? "9999px" : undefined,
}} />
