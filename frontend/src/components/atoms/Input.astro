---
export interface Props {
  label?: string;
  name: string;
  type?: "text" | "email" | "password" | "number" | "tel" | "url";
  placeholder?: string;
  error?: string;
  icon?: "search" | "email" | "lock" | "user";
  class?: string;
  required?: boolean;
  value?: string;
}

const { label, name, type = "text", placeholder, error, icon, class: className = "", required = false, value } = Astro.props;
---

<div class={`flex flex-col gap-1.5 ${className}`}>
  {label && <label for={name} class="text-sm font-medium text-text-primary">{label}</label>}
  <div class="relative">
    {icon && (
      <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-text-muted">
        {icon === "search" && "🔍"}
        {icon === "email" && "✉"}
        {icon === "lock" && "🔒"}
        {icon === "user" && "👤"}
      </span>
    )}
    <input
      id={name}
      name={name}
      type={type}
      placeholder={placeholder}
      required={required}
      value={value}
      class={`w-full rounded-lg border bg-bg-tertiary px-4 py-2.5 text-sm text-text-primary transition-colors placeholder:text-text-muted focus:border-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-500/20 ${icon ? "pl-10" : ""} ${error ? "border-red-500 focus:border-red-500 focus:ring-red-500/20" : "border-border"}`}
    />
  </div>
  {error && <p class="text-xs text-red-600">{error}</p>}
</div>
