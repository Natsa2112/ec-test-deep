---
export interface Props {
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { size = "md", class: className = "" } = Astro.props;

const sizes = {
  sm: "h-4 w-4 border-2",
  md: "h-6 w-6 border-2",
  lg: "h-8 w-8 border-3",
};
---

<div class={`flex items-center justify-center ${className}`}>
  <div class={`animate-spin rounded-full border-primary border-t-transparent ${sizes[size]}`} />
</div>
