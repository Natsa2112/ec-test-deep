---
export interface Props {
  variant?: "success" | "warning" | "danger" | "info" | "neutral";
  class?: string;
}

const { variant = "neutral", class: className = "" } = Astro.props;

const variants = {
  success: "bg-emerald-900/50 text-emerald-300",
  warning: "bg-amber-900/50 text-amber-300",
  danger: "bg-red-900/50 text-red-300",
  info: "bg-blue-900/50 text-blue-300",
  neutral: "bg-bg-elevated text-text-secondary",
};
---

<span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ${variants[variant]} ${className}`}>
  <slot />
</span>
