---
export interface Props {
  ctaText?: string;
  ctaHref?: string;
  class?: string;
}

const { ctaText = "Ver ofertas", ctaHref = "/ofertas", class: className = "" } = Astro.props;
---

<section class={`py-16 ${className}`}>
  <div class="mx-auto max-w-6xl px-4 text-center">
    <h2 class="mb-4 text-2xl font-bold text-text-primary">¿Listo para comprar?</h2>
    <p class="mb-6 text-text-secondary">Aprovechá nuestras ofertas con envío gratis y cuotas sin interés.</p>
    <a href={ctaHref} class="inline-flex items-center rounded-lg bg-violet-600 px-8 py-3 text-sm font-semibold text-white hover:bg-violet-500 transition-colors">
      {ctaText}
    </a>
  </div>
</section>
