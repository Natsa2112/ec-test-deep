---
export interface Props {
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaHref?: string;
  class?: string;
}

const { title, subtitle, ctaText, ctaHref = "/productos", class: className = "" } = Astro.props;
---

<section class={`relative overflow-hidden bg-gradient-to-br from-violet-950 via-bg-primary to-bg-primary py-20 ${className}`}>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--color-violet-900)_0%,_transparent_60%)] opacity-30" />
  <div class="mx-auto max-w-6xl px-4 text-center relative">
    <h1 class="mb-4 text-4xl font-bold tracking-tight text-text-primary md:text-5xl lg:text-6xl">{title}</h1>
    <p class="mx-auto mb-8 max-w-2xl text-lg text-text-secondary">{subtitle}</p>
    {ctaText && (
      <a href={ctaHref} class="inline-flex items-center rounded-lg bg-violet-600 px-8 py-3 text-sm font-semibold text-white hover:bg-violet-500 transition-colors focus:outline-none focus:ring-2 focus:ring-violet-500/50 focus:ring-offset-2 focus:ring-offset-bg-primary">
        {ctaText}
      </a>
    )}
  </div>
</section>
